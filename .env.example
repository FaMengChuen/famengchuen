# === Firebase Web client (público, NEXT_PUBLIC_*) ===
# Se obtienen con: firebase apps:sdkconfig WEB <appId>
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# === Firebase Admin (servidor) ===
# Service account en base64 (Project Settings → Service Accounts → Generate key,
# luego: base64 -i service-account.json). lib/firebase/admin.ts también acepta el
# JSON crudo o FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY por separado.
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_STORAGE_BUCKET=

# === Roles ===
# Owners iniciales (coma-separados). NO se pueden revocar desde la UI.
FIREBASE_OWNER_EMAILS=

# === Vercel Blob (subida de imágenes) ===
# Crea un store Blob en el panel de Vercel (Storage → Create → Blob) y copia el
# token. En producción se inyecta solo al enlazar el store al proyecto.
BLOB_READ_WRITE_TOKEN=
