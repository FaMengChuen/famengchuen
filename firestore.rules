rules_version = '2';

// Todo el contenido del CMS se lee y escribe desde el servidor con el
// Firebase Admin SDK (que omite estas reglas). El navegador NUNCA accede
// directamente a Firestore: el login Google solo usa Auth y las subidas
// pasan por las APIs internas /api/admin/*. Por eso bloqueamos todo acceso
// directo de clientes.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
